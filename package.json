{
    "schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build && cp -r public/* dist/ && cp -r api app bootstrap config database routes storage vendor artisan composer.json dist/",
        "vite:build": "vite build",
        "deploy": "vite build",
        "dev": "npx concurrently -c \"#93c5fd,#c4b5fd\" \"php artisan serve\" \"vite\" --names=server,vite --kill-others",
        "dev:frontend": "vite",
        "serve": "npm run dev",
        "vite": "vite"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.16.1",
        "concurrently": "^7.6.0",
        "laravel-vite-plugin": "^2.0.0",
        "rxjs": "^7.8.2",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.0"
    },
    "dependencies": {
        "@marsidev/react-turnstile": "^1.5.2",
        "@radix-ui/react-slot": "^1.2.4",
        "@vitejs/plugin-react": "^4.2.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.16.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-router-dom": "^7.15.1",
        "tailwind-merge": "^3.6.0",
        "zustand": "^5.0.13"
    }
}
